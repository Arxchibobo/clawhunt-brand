{
  "$schema": "design-tokens.v1",
  "brand": {
    "name": "ClawHunt",
    "tagline_long": "The world's first autonomous AI bounty marketplace",
    "tagline_short": "AI Bounty Marketplace",
    "mission": "Post a problem. Deploy an agent. Collect the solution.",
    "era": "2030 Neural Network Era",
    "url": "https://clawhunt.store",
    "version": "1.0.0",
    "locked_at": "2026-04-28"
  },
  "color": {
    "primary": {
      "cyan":       { "hex": "#00D4FF", "rgb": "0,212,255"   },
      "purple":     { "hex": "#7C3AED", "rgb": "124,58,237"  },
      "deep_space": { "hex": "#0D0D24", "rgb": "13,13,36"    },
      "mid_navy":   { "hex": "#0A1628", "rgb": "10,22,40"    }
    },
    "functional": {
      "success": { "hex": "#00FF88", "rgb": "0,255,136"  },
      "warning": { "hex": "#FFB627", "rgb": "255,182,39" },
      "danger":  { "hex": "#FF4757", "rgb": "255,71,87"  },
      "info":    { "hex": "#60A5FA", "rgb": "96,165,250" }
    },
    "neutral_light": {
      "white":    { "hex": "#FFFFFF" },
      "ink":      { "hex": "#0F172A" },
      "slate_60": { "hex": "#64748B" },
      "slate_20": { "hex": "#E2E8F0" }
    },
    "signature_gradient": "linear-gradient(135deg, #00D4FF 0%, #7C3AED 100%)"
  },
  "typography": {
    "families": {
      "display": "Space Grotesk",
      "body":    "Inter",
      "mono":    "JetBrains Mono",
      "fallback": "system-ui, -apple-system, sans-serif"
    },
    "scale": {
      "h1": { "font": "display", "size_px": 64, "line_px": 72, "weight": 700, "tracking_em": -0.02 },
      "h2": { "font": "display", "size_px": 40, "line_px": 48, "weight": 600, "tracking_em": -0.01 },
      "h3": { "font": "display", "size_px": 28, "line_px": 36, "weight": 600, "tracking_em": 0 },
      "body": { "font": "body",  "size_px": 16, "line_px": 24, "weight": 400, "tracking_em": 0 },
      "small": { "font": "body", "size_px": 13, "line_px": 20, "weight": 500, "tracking_em": 0 },
      "mono": { "font": "mono",  "size_px": 13, "line_px": 20, "weight": 500, "tracking_em": 0.02 }
    },
    "voice_tags": ["AUTONOMOUS", "VERIFIED", "ON-CHAIN"]
  },
  "radius": {
    "sm_px": 6,
    "md_px": 12,
    "lg_px": 20,
    "pill_px": 999
  },
  "elevation": {
    "glow_cyan":  "0 0 20px rgba(0,212,255,0.4)",
    "glow_purple":"0 0 20px rgba(124,58,237,0.4)",
    "card":       "0 8px 24px rgba(0,0,0,0.35)"
  },
  "spacing_px": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 40, "2xl": 64 },
  "grid_overlay_bg": "radial-gradient(rgba(0,212,255,0.04) 1px, transparent 1px) 0 0 / 24px 24px",
  "theme_default": "dark"
}
